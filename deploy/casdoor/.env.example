# Casdoor 部署配置 — 复制为 .env 并按生产环境改。切勿把真实 .env 提交进 git。
# docker-compose 会自动读取同目录 .env。

# ── Postgres ──
CASDOOR_DB_USER=casdoor
CASDOOR_DB_PASSWORD=change-me-to-a-strong-secret   # 生产必改!丢了这个连不上库
CASDOOR_DB_NAME=casdoor
CASDOOR_DB_PORT=5433

# ── Casdoor ──
# 生产钉住 digest,别用 :latest(可复现 + 防上游意外变更)
CASDOOR_IMAGE=casbin/casdoor:latest
CASDOOR_PORT=8000

# ── 备份(backup.sh 读取) ──
CASDOOR_BACKUP_DIR=./backups           # pg_dump 输出目录
CASDOOR_BACKUP_KEEP=14                 # 保留最近 N 份

# 提醒(不在本文件、但生产必做):
#  1) 首次登录 Casdoor 立刻把内置 admin/123 改成强密码。
#  2) 治理服务(even-auth-gov)的密钥:FEISHU_APP_SECRET / CASDOOR_CLIENT_SECRET /
#     CASDOOR_WEBHOOK_SECRET / SESSION_SECRET 落到密管,不写死。
